ZEKO_GRAPHQL=https://YOUR_ZEKO_GRAPHQL_ENDPOINT
# optional dedicated endpoint for tx-hash lookup verification (if ZEKO_GRAPHQL lacks tx fields)
ZEKO_TX_GRAPHQL=
# optional aliases for archive infrastructure
ZEKO_ARCHIVE_GRAPHQL=
ZEKO_ARCHIVE_RELAY_GRAPHQL=
# optional metadata only (scripts use ZEKO_GRAPHQL endpoint directly)
ZEKO_NETWORK_ID=testnet
TX_FEE=100000000

# deploy key for sender account
DEPLOYER_PRIVATE_KEY=EKF...
# private key for zkapp account (deployment)
ZKAPP_PRIVATE_KEY=EKF...
# public key for already deployed zkapp (commit/get-state)
ZKAPP_PUBLIC_KEY=B62q...

# market identity configured at deploy time
MARKET_SYMBOL=tETH/tZEKO
BASE_TOKEN_ID=wpWnRKT383VPM2TWtBWs8R4i927SKUgzAycsSs3AyvyriGXyP2
QUOTE_TOKEN_ID=x3jovPY75iFmbZ5kTfxZmNmEQ6874mmBu3jufom1QsxMNqPx27

# optional dedicated operator key (defaults to deployer pubkey)
OPERATOR_PUBLIC_KEY=B62q...
# optional fallback wallet gate when no admin key is configured
OPERATOR_PANEL_ALLOWED_WALLET=B62q...
OPERATOR_PANEL_ADMIN_KEY=change-me-operator-admin-key

# server/runtime
DARKPOOL_PORT=8791
DARKPOOL_HOST=0.0.0.0
AUTO_RUN_BACKGROUND_WORKERS=false
AUTO_RUN_PROOF_WORKER=false
AUTO_RUN_SETTLEMENT_WORKER=false
BACKGROUND_WORKER_RESTART_DELAY_MS=3000
PROOF_WORKER_API_KEY=change-proof-worker-key
ZEKO_FAUCET_COMMAND="npx -y @zeko-labs/faucet-cli"
ZEKO_FAUCET_GITHUB_TOKEN=ghp_your_faucet_token
ORDER_RECEIPT_SECRET=change-me
EARLY_ACCESS_GATE_ENABLED=false
EARLY_ACCESS_CODES=
EARLY_ACCESS_COOKIE_NAME=shadowbook_access
EARLY_ACCESS_COOKIE_SECRET=
MAKER_API_KEY=change-maker-key
TAKER_FEE_BPS=5
FRONTEND_FEE_SHARE_BPS=3000
ONCHAIN_SYNC_TTL_MS=60000
REQUIRE_ONCHAIN_DEPOSIT_TX=true
ALLOW_WALLET_TX_HASH_FALLBACK=true
# recipient wallet used for note-mint deposit tx verification
VAULT_DEPOSIT_ADDRESS=B62q...
# optional auto-expiry for standing GTC orders (0 disables expiry)
GTC_ORDER_EXPIRY_MS=0
# convert raw on-chain integer balances into human units for tracked assets
ASSET_DECIMALS_JSON={"tETH":9,"tZEKO":9,"tMINA":9}
ORDER_STATE_ENCRYPTION_KEY=change-engine-state-key
BOOK_ANCHOR_INTERVAL_MS=0
DA_MODE=zeko-relay
DA_ENDPOINT=http://127.0.0.1:8787/publish
DA_BEARER_TOKEN=
DA_REQUIRE_ENCRYPTION=true
DA_INCLUDE_ORDER_SNAPSHOT=false
DA_ENCRYPTION_KEY=change-da-encryption-key
ZEKO_DA_NETWORK=testnet
ZEKO_DA_APP_ID=shadowbook
ZEKO_DA_SCHEMA=shadowbook.da.v1

# local DA relay service (recommended for zeko-relay mode)
DA_RELAY_PORT=8787
DA_RELAY_FORWARD_MODE=zeko-bridge
# set this when you have an HTTP bridge that writes into Zeko DA Async RPC
ZEKO_DA_BRIDGE_URL=
ZEKO_DA_BRIDGE_TOKEN=
ZEKO_DA_NAMESPACE=shadowbook
ZEKO_DA_REQUIRE_FORWARD=true
DA_RELAY_FORWARD_RETRIES=3
DA_RELAY_FORWARD_TIMEOUT_MS=15000
# optional: command hook for custom submitter
DA_RELAY_COMMAND=
DA_RELAY_SECRET=change-da-relay-secret

# keep local shortcut disabled for real on-chain flow
ENABLE_LOCAL_SETTLEMENT=false
AUTO_SETTLEMENT=false
AUTO_SETTLEMENT_INTERVAL_MS=5000

# settlement worker
SETTLEMENT_MODE=zkapp
SETTLEMENT_INTERVAL_MS=6000
SETTLEMENT_REQUIRE_ONCHAIN_PAYOUTS=true
SETTLEMENT_REQUIRE_PAYOUT_PROOFS=true
SETTLEMENT_ALLOW_UNVERIFIED_PAYOUTS=false
# default worker command is: node scripts/settlement-payout-executor.js
# optional override command must return {"payoutTxs":[{"wallet":"...","tokenId":"...","txHash":"..."}]}
SETTLEMENT_PAYOUT_COMMAND="node scripts/settlement-payout-executor.js"
ZKAPP_COMMIT_MAX_OLD_SPACE_MB=12288
PRIVATE_STATE_PROVER_MAX_OLD_SPACE_MB=4096
ZKAPP_DEPLOY_MAX_OLD_SPACE_MB=12288
PRIVATE_STATE_PROOF_INTERVAL_MS=4000
PRIVATE_STATE_PROOF_COMMAND="node --enable-source-maps dist-zkapp/prove-private-state-batch.js"
ZKAPP_COMMIT_USE_PROOF=false
REQUIRE_CACHED_PRIVATE_STATE_PROOF=false
ALLOW_INLINE_PRIVATE_STATE_PROVING=false
ZKAPP_COMMIT_COMMAND="node --enable-source-maps dist-zkapp/commit-next-batch.js"
# signer for payout source wallet (must match VAULT_DEPOSIT_ADDRESS)
PAYOUT_OPERATOR_PRIVATE_KEY=EKF...
# optional separate fee payer key (defaults to PAYOUT_OPERATOR_PRIVATE_KEY)
PAYOUT_FEE_PAYER_PRIVATE_KEY=

# bot defaults for tETH/tZEKO
BOT_PAIR=tETH/tZEKO
BOT_MARKET_ID=
BOT_BASE_TOKEN_ID=wpWnRKT383VPM2TWtBWs8R4i927SKUgzAycsSs3AyvyriGXyP2
BOT_QUOTE_TOKEN_ID=x3jovPY75iFmbZ5kTfxZmNmEQ6874mmBu3jufom1QsxMNqPx27
BOT_BASE_ASSET=tETH
BOT_QUOTE_ASSET=tZEKO
BOT_MAKER_WALLET=B62qbot_maker_wallet
BOT_TAKER_WALLET=B62qbot_taker_wallet
BOT_AUTO_FUND=false
BOT_REAL_FUNDS=true
